# Environment
NODE_ENV=development
PORT=4404

# Database - MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=monetrapos

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
CACHE_TTL=300

# JWT
JWT_SECRET=MonetraPOS-dev-secret-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=MonetraPOS-dev-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# API URLs
API_URL=http://10.1.2.254:4404
COMPANY_ADMIN_URL=http://10.1.2.254:4402
MEMBER_ADMIN_URL=http://10.1.2.254:4403

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Midtrans - REMOVED (using Xendit only, configured via admin panel)
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=

# Xendit Payment Gateway
# Masukkan secret key Xendit Anda di sini (dimulai dengan xnd_development_ atau xnd_production_)
XENDIT_SECRET_KEY=xnd_development_yFyaLqko6C3oy8UU8Fz1id4LbJ2zDAzi73dqObkTvmtrEV5sGGdVO3RkLcIJCTa
XENDIT_WEBHOOK_TOKEN=sYiQSshlfgwBTKsOn8B79Kshy52tw9DApTCiXubcTOPeINph
XENDIT_IS_PRODUCTION=false

# Email (Optional - bisa dikosongkan untuk testing)
# Konfigurasi email dikelola via Company Admin → Settings → Email Config
# Nilai di bawah hanya sebagai fallback jika database belum dikonfigurasi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MonetraPOS <noreply@monetrapos.com>

# Mailtrap (untuk testing - isi jika ingin fallback via env)
# MAILTRAP_HOST=sandbox.smtp.mailtrap.io
# MAILTRAP_PORT=2525
# MAILTRAP_USER=your_mailtrap_username
# MAILTRAP_PASS=your_mailtrap_password

# Gmail App Password (untuk production - isi jika ingin fallback via env)

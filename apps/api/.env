# Environment
NODE_ENV=development
PORT=4404

# Database - MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=monetrapos

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
CACHE_TTL=300

# JWT
JWT_SECRET=monetrapos-dev-secret-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=monetrapos-dev-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# API URLs
API_URL=http://localhost:4404
COMPANY_ADMIN_URL=http://localhost:4402
MEMBER_ADMIN_URL=http://localhost:4403

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Midtrans - REMOVED (using Xendit only, configured via admin panel)
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=

# Xendit Payment Gateway - configured via admin panel, not .env
# XENDIT_SECRET_KEY=
# XENDIT_WEBHOOK_TOKEN=

# Email (Optional - bisa dikosongkan untuk testing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MonetRAPOS <noreply@monetrapos.com>

# Sentry (Optional - bisa dikosongkan)
SENTRY_DSN=

# Frontend URLs
FRONTEND_URL=http://localhost:4403

{
  "name": "monetrapos",
  "version": "1.0.0",
  "private": true,
  "description": "MonetRAPOS - Multi-Business POS Application",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev --workspace=apps/api",

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Build outputs ───────────────────────────────────────────────────────────
dist/
build/
out/
.next/
**/.next/
apps/api/dist/

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
# Keep example files
!.env.example
!**/.env.example

# ─── Uploaded files (user content — should NOT be in git) ────────────────────
uploads/
**/uploads/
apps/api/uploads/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE & Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# ─── Testing & Coverage ──────────────────────────────────────────────────────
coverage/
**/coverage/
.nyc_output/
*.lcov

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
**/tsconfig.tsbuildinfo

# ─── Cache ───────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.cache

# ─── Docker ──────────────────────────────────────────────────────────────────
# Keep Dockerfiles, ignore local docker volumes
.docker/

# ─── Misc ────────────────────────────────────────────────────────────────────
temp/
tmp/
*.tmp
*.bak
*.orig
*.pid
*.seed
*.pid.lock

# ─── Package manager locks (keep only one) ───────────────────────────────────
# Uncomment the ones you DON'T use:
# yarn.lock
# pnpm-lock.yaml

# ─── SSL Certificates ────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ─── Database ────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
